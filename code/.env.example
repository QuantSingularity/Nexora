# Nexora Environment Configuration
# Copy this file to .env and adjust values for your environment

# REST API
PORT=8000
HOST=0.0.0.0

# gRPC Server
GRPC_PORT=50051
GRPC_MAX_WORKERS=10

# Streamlit UI
UI_PORT=8501

# FHIR Server
FHIR_SERVER_URL=http://mock-fhir-server/R4

# Audit Database
AUDIT_DB_PATH=/app/audit/phi_access.db

# Logging
LOG_LEVEL=INFO
